{
  "name": "rentvine-mcp",
  "version": "0.1.3",
  "description": "MCP server for Rentvine property management — works with Claude Desktop, Claude Code, Cursor, and any MCP client",
  "type": "module",
  "bin": {
    "rentvine-mcp": "dist/index.js",
    "rentvine-mcp-http": "dist/http.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js dist/http.js",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "version": "node -e \"const f='manifest.json';const m=require('./'+f);m.version=require('./package.json').version;require('fs').writeFileSync(f,JSON.stringify(m,null,2)+'\\n')\" && git add manifest.json"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Base-Homes/rentvine-mcp.git"
  },
  "homepage": "https://github.com/Base-Homes/rentvine-mcp#readme",
  "bugs": {
    "url": "https://github.com/Base-Homes/rentvine-mcp/issues"
  },
  "keywords": [
    "mcp",
    "rentvine",
    "property-management",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
